<!-- Product Popup Modal Snippet for Tisso In The Wild Grid -->
<div id="product-popup-overlay" class="product-popup-overlay" hidden>
  <div class="product-popup" role="dialog" aria-modal="true">
    <button class="product-popup__close" id="product-popup-close" aria-label="Close">&times;</button>

    <div class="product-popup__top-row">
      <div class="product-popup__image-wrap">
        <img id="popup-product-image" class="product-popup__image" src="" alt="">
      </div>
      <div class="product-popup__info">
        <h3 id="popup-product-title" class="product-popup__title"></h3>
        <p id="popup-product-price" class="product-popup__price"></p>
        <div id="popup-product-description" class="product-popup__description"></div>
      </div>
    </div>

    <div id="popup-options-wrap"></div>

    <button id="popup-add-to-cart" class="product-popup__add-btn" type="button" disabled>
      <span>ADD TO CART</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>
