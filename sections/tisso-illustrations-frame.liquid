<!-- Tisso Illustrations Frame -->
<section class="tisso-frame" id="tisso-frame-{{ section.id }}" style="
  background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  padding-block-start: {{ section.settings.padding_top }}px;
  padding-block-end: {{ section.settings.padding_bottom }}px;
">
  <div class="tisso-frame__container" style="max-width: {{ section.settings.max_width }}px;">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="tisso-frame__link" aria-label="View collection">
      </a>
    {% endif %}
  </div>
</section>

<style>
  .tisso-frame {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .tisso-frame__container {
    width: 100%;
    padding-inline-start: 48px;
    padding-inline-end: 48px;
    display: flex;
    justify-content: center;
  }

  .tisso-frame__link {
    display: block;
    width: 100%;
  }

  .tisso-frame__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    /* Optional hover animation matching the boutique feel */
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .tisso-frame__img:hover {
    transform: scale(1.01);
  }

  @media (max-width: 749px) {
    .tisso-frame__container {
      padding-inline-start: 16px;
      padding-inline-end: 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Tisso Illustrations Frame",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum Width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "url",
      "id": "link",
      "label": "Section Link (Optional)"
    }
  ],
  "presets": [
    {
      "name": "Tisso Illustrations Frame"
    }
  ]
}
{% endschema %}
