<!-- Custom Banner Section -->
<section class="custom-banner" id="custom-banner-{{ section.id }}" style="
  {% if section.settings.bg_image != blank %}
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
  {% else %}
    background-image: url('{{ 'Frame.svg' | asset_url }}');
  {% endif %}
">
  <div class="custom-banner__container">
    <div class="custom-banner__content">
      {% if section.settings.heading != blank %}
        <h2 class="custom-banner__title">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="custom-banner__text">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.btn_text != blank %}
        <a href="{{ section.settings.btn_link | default: '#' }}" class="custom-banner__btn">
          {{ section.settings.btn_text }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .custom-banner {
    position: relative;
    width: 100%;
    min-height: 390px;
    background-size: cover;
    background-position: top center;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    overflow: hidden;
  }

  .custom-banner__container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 48px;
    box-sizing: border-box;
    display: flex;
    justify-content: flex-start;
  }

  .custom-banner__content {
    max-width: 440px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    z-index: 2;
  }

  .custom-banner__title {
    font-size: 48px;
    font-weight: 600;
    color: #000000;
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-family: var(--font-heading--family, Georgia, serif);
  }

  .custom-banner__text {
    font-size: 14px;
    line-height: 1.6;
    color: #000000;
    margin: 0;
  }

  .custom-banner__text p {
    margin: 0;
  }

  .custom-banner__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: #000000;
    color: #ffffff;
    padding: 14px 32px;
    text-decoration: none;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: background-color 0.3s ease, transform 0.3s ease;
    border: none;
  }

  .custom-banner__btn:hover {
    background-color: #333333;
    transform: translateX(3px);
  }

  .custom-banner__btn svg {
    transition: transform 0.3s ease;
  }

  .custom-banner__btn:hover svg {
    transform: translateX(4px);
  }

  /* Tablet and Mobile Responsiveness */
  @media (max-width: 768px) {
    .custom-banner {
      min-height: 350px;
    }

    .custom-banner__container {
      padding: 24px;
    }

    .custom-banner__content {
      background-color: rgba(255, 255, 255, 0.85);
      padding: 24px;
      gap: 12px;
    }

    .custom-banner__title {
      font-size: 36px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Upload the background image (e.g. Frame.svg)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts.</p>"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}