<section class="gift-guide-banner" style="background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');">
  <div class="banner-container">
    <div class="banner-content">
      {% if section.settings.heading != blank %}
        <h1 class="banner-title">{{ section.settings.heading }}</h1>
      {% endif %}
      
      {% if section.settings.description != blank %}
        <div class="banner-text">{{ section.settings.description }}</div>
      {% endif %}
      
      {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
        <a href="{{ section.settings.btn_link }}" class="banner-btn">
          {{ section.settings.btn_text }}
          <!-- سهم الزرار مطابق لتصميم فيجما -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .gift-guide-banner {
    width: 100%;
    min-height: 500px;
    background-size: cover;
    background-position: center;
    background-color: #f8f8f8; /* لون احتياطي لو مفيش صورة */
    display: flex;
    align-items: center;
    padding: 40px 5%;
    position: relative;
  }
  .banner-container {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
  }
  .banner-content {
    max-width: 450px; /* عشان النص ميفردش بعرض الشاشة زي التصميم */
  }
  .banner-title {
    font-size: 52px;
    font-weight: 600;
    color: #000;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .banner-text {
    font-size: 16px;
    color: #000;
    margin-bottom: 30px;
    line-height: 1.5;
  }
  .banner-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #000;
    color: #fff;
    padding: 14px 28px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 1px;
    gap: 12px;
    transition: background-color 0.3s ease;
  }
  .banner-btn:hover {
    background-color: #333;
  }
  
  /* تظبيط الموبايل */
  @media (max-width: 768px) {
    .gift-guide-banner {
      min-height: 400px;
      justify-content: center;
      text-align: center;
    }
    .banner-title {
      font-size: 36px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}