<section class="gift-guide-banner" style="background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');">
  <div class="banner-container">
    <div class="banner-content">
      {% if section.settings.heading != blank %}
        <h1 class="banner-title">{{ section.settings.heading }}</h1>
      {% endif %}
      
      {% if section.settings.description != blank %}
        <div class="banner-text">{{ section.settings.description }}</div>
      {% endif %}
      
      {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
        <a href="{{ section.settings.btn_link }}" class="banner-btn">
          {{ section.settings.btn_text }}
          <svg width="20" height="10" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-left: 10px;">
            <path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .gift-guide-banner {
    width: 100%;
    /* ارتفاع مطابق لفيجما بالظبط */
    min-height: 390px; 
    background-size: cover; 
    /* ضبط نقطة ارتكاز الصورة عشان تناسب التصميم */
    background-position: top center; 
    background-repeat: no-repeat;
    background-color: #ffffff;
    display: flex;
    /* محاذاة المحتوى للأسفل عشان النص ينزل في المساحة الفاضية */
    align-items: flex-end; 
    padding: 0 5% 40px 5%; 
    box-sizing: border-box;
  }
  .banner-container {
    max-width: 1440px; 
    width: 100%;
    margin: 0 auto;
    display: flex;
    justify-content: flex-start;
  }
  .banner-content {
    /* تحديد عرض النص عشان ما يدخلش على الرسومات */
    max-width: 440px; 
  }
  .banner-title {
    font-size: 48px;
    font-weight: 600;
    color: #000;
    margin-bottom: 15px;
    line-height: 1.1;
    letter-spacing: -0.5px;
  }
  .banner-text {
    font-size: 14px;
    color: #000;
    margin-bottom: 30px;
    line-height: 1.5;
  }
  .banner-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #000;
    color: #fff;
    padding: 14px 32px;
    text-decoration: none;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    transition: background-color 0.3s ease;
  }
  .banner-btn:hover {
    background-color: #333;
  }
  
  /* تظبيط شكل البانر على الموبايل عشان الرسمة متختفيش */
  @media (max-width: 768px) {
    .gift-guide-banner {
      min-height: 350px;
      align-items: flex-end;
      padding-bottom: 30px;
      background-position: 70% top;
    }
    .banner-title {
      font-size: 36px;
    }
    .banner-content {
      background: rgba(255, 255, 255, 0.85); /* خلفية شفافة بسيطة للنص على الموبايل عشان يتقري */
      padding: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination.<br>Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}