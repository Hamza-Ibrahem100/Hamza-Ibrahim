<!-- Tisso Illustrations Collage - Modular Block-based Customizer Section -->
<section class="tisso-collage" id="tisso-collage-{{ section.id }}" style="background-color: {{ section.settings.bg_color | default: '#ffffff' }};">
  <div class="tisso-collage__wrapper">
    <div class="tisso-collage__container">
      {% for block in section.blocks %}
        {% if block.settings.illustration_type != blank %}
          <div class="tisso-collage__item-wrap" {{ block.shopify_attributes }} style="
            top: {{ block.settings.position_top }}%;
            left: {{ block.settings.position_left }}%;
            width: {{ block.settings.width }}%;
          ">
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="tisso-collage__link" aria-label="View link">
            {% endif %}

            <img
              src="{{ block.settings.illustration_type | asset_url }}"
              class="tisso-collage__img"
              alt=""
              loading="lazy"
            >

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .tisso-collage {
    width: 100%;
    position: relative;
    overflow: hidden;
    padding: 40px 0;
  }

  .tisso-collage__wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
  }

  /* Centered aspect-ratio locked container to keep positions pixel-perfect on resize */
  .tisso-collage__container {
    position: relative;
    width: 100%;
    aspect-ratio: 1440 / 520;
    overflow: visible;
  }

  .tisso-collage__item-wrap {
    position: absolute;
    display: block;
    transform: translateY(0);
    transition: transform 0.3s ease;
  }

  .tisso-collage__item-wrap:hover {
    transform: translateY(-4px);
    z-index: 10;
  }

  .tisso-collage__link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .tisso-collage__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* Mobile responsive styling */
  @media (max-width: 749px) {
    .tisso-collage__wrapper {
      padding: 0 16px;
    }
    
    /* Make spacing more compact on mobile */
    .tisso-collage__container {
      aspect-ratio: 1440 / 720;
    }
  }
</style>

