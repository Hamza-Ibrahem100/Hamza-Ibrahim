<!-- Gift Guide Hero Banner -->
<section class="gift-hero" id="gift-hero-section-{{ section.id }}" style="
  background-color: {{ section.settings.bg_color | default: '#ffffff' }};
">
  <div class="gift-guide-hero__bg-wrapper">
    <img
      src="{% if section.settings.bg_image != blank %}{{ section.settings.bg_image | image_url: width: 2400 }}{% else %}{{ 'Frame.svg' | asset_url }}{% endif %}"
      class="gift-guide-hero__bg-image"
      alt="{{ section.settings.heading | default: 'Gift guide illustrations' }}"
      loading="eager"
    >
  </div>

  <div class="gift-hero__wrapper">
    <!-- Centered container for content overlay & illustration frame -->
    <div class="gift-hero__collage-container">

      <!-- Live Text Content overlaid on the left side of the banner -->
      <div class="gift-hero__content-box">
        {% if section.settings.heading != blank %}
          <h1 class="gift-hero__title" style="color: {{ section.settings.heading_color | default: '#000000' }};">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="gift-hero__description" style="color: {{ section.settings.text_color | default: '#1a1a1a' }};">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.settings.btn_text != blank %}
          <a href="{{ section.settings.btn_link | default: '#' }}" class="gift-hero__btn" style="
            background-color: {{ section.settings.btn_bg_color | default: '#000000' }};
            color: {{ section.settings.btn_text_color | default: '#ffffff' }};
          ">
            {{ section.settings.btn_text }}
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>

    </div>
  </div>

  <!-- Bottom tagline -->
  {% if section.settings.bottom_text != blank %}
    <div class="gift-hero__tagline" style="color: {{ section.settings.tagline_color | default: '#555555' }};">
      {{ section.settings.bottom_text }}
    </div>
  {% endif %}
</section>

<style>
  .gift-hero {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  .gift-guide-hero__bg-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .gift-guide-hero__bg-image {
    position: absolute;
    width: 2373.33px;
    height: 1072px;
    top: -536px;
    left: 50%;
    transform: translateX(-50%);
    max-width: none;
    opacity: 1;
    display: block;
  }

  .gift-hero__wrapper {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 20px 48px;
    position: relative;
    z-index: 2;
  }

  /* Centered aspect-ratio locked container (locked to Figma viewport ratio 1440x620) */
  .gift-hero__collage-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1440 / 620;
    overflow: visible;
  }

  /* Text Content Box Positioned exactly inside the Figma empty space */
  .gift-hero__content-box {
    position: absolute;
    left: 8%;
    top: 40%;
    width: 28%;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .gift-hero__title {
    font-size: 48px;
    font-weight: 700;
    margin: 0 0 18px 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-family: var(--font-heading--family, Georgia, 'Times New Roman', serif);
  }

  .gift-hero__description {
    font-size: 14px;
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 370px;
  }

  .gift-hero__description p {
    margin: 0;
  }

  .gift-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    border: none;
  }

  .gift-hero__btn:hover {
    background-color: #d4e600 !important;
    color: #000000 !important;
    transform: translateX(3px);
  }

  .gift-hero__btn svg {
    transition: transform 0.3s ease;
  }

  .gift-hero__btn:hover svg {
    transform: translateX(5px);
  }

  /* Positioned Illustration wraps */
  .gift-hero__illustration-wrap {
    position: absolute;
    display: block;
    transform: translateY(0);
    transition: transform 0.3s ease;
    z-index: 1;
  }

  .gift-hero__illustration-wrap:hover {
    transform: translateY(-4px);
    z-index: 10;
  }

  .gift-hero__illustration-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .gift-hero__illustration-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* Bottom Tagline */
  .gift-hero__tagline {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 16px 40px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    border-top: 1px solid rgba(0,0,0,0.08);
    background-color: rgba(255,255,255,0.85);
  }

  /* Tablet */
  @media (max-width: 991px) {
    .gift-hero__wrapper {
      padding: 15px 30px;
    }

    .gift-hero__title {
      font-size: 36px;
      margin-bottom: 12px;
    }

    .gift-hero__description {
      font-size: 13px;
      margin-bottom: 20px;
    }
  }

  /* Mobile Layout - Stacks elements to fit small screens */
  @media (max-width: 749px) {
    .gift-hero__wrapper {
      padding: 0 16px;
    }

    .gift-hero__collage-container {
      aspect-ratio: auto;
      display: flex;
      flex-direction: column;
      padding: 40px 0;
    }

    .gift-hero__content-box {
      position: static;
      width: 100%;
      margin-bottom: 40px;
      align-items: center;
      text-align: center;
    }

    .gift-hero__title {
      font-size: 32px;
    }

    .gift-hero__btn {
      width: 100%;
      justify-content: center;
    }

    .gift-hero__tagline {
      font-size: 8px;
      letter-spacing: 1.5px;
      padding: 14px 16px;
    }

    /* Hide individual illustration blocks on mobile to stay clean and load fast */
    .gift-hero__illustration-wrap {
      display: none;
    }
  }
</style>

