    <img src="{{ 'illustration-Vector-19.svg' | asset_url }}" class="gift-hero__item" style="top: -2%; left: 48%; width: 13%;" alt="" loading="eager">
    
    <!-- Bow tie (Vector-22.svg - 208x348) -->
    <img src="{{ 'illustration-Vector-22.svg' | asset_url }}" class="gift-hero__item" style="top: -8%; left: -2%; width: 15%;" alt="" loading="eager">
    
