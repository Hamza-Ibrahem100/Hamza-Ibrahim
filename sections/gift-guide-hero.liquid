    <!-- Camera parts (Vector-7.svg) -->
    <img src="{{ 'illustration-Vector-7.svg' | asset_url }}" class="gift-hero__item" style="top: 2%; left: 30%; width: 12%;" alt="" loading="eager">
    
    <!-- Large Camera (Vector-8.svg - 318x214) -->
    <img src="{{ 'illustration-Vector-8.svg' | asset_url }}" class="gift-hero__item" style="top: 2%; left: 13%; width: 23%;" alt="" loading="eager">
    
    <!-- Flash unit (Vector-9.svg - 134x193) -->
    <img src="{{ 'illustration-Vector-9.svg' | asset_url }}" class="gift-hero__item" style="top: -3%; left: 60%; width: 10%;" alt="" loading="eager">
    
    <!-- Small details (Vector-10.svg - 263x195) -->
    <img src="{{ 'illustration-Vector-10.svg' | asset_url }}" class="gift-hero__item" style="top: 16%; left: 56%; width: 19%;" alt="" loading="eager">
    
