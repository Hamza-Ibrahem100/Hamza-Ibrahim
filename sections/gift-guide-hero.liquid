<!-- Gift Guide Hero Banner - Using Original Figma SVG Illustrations -->
<section class="gift-hero" id="gift-hero-section" style="{% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');{% endif %}">
  
