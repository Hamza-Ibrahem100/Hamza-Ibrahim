    <img src="{{ 'illustration-Vector-31.svg' | asset_url }}" class="gift-hero__item" style="top: 5%; left: 82%; width: 9%;" alt="" loading="eager">
    
    <!-- Camera body 2 (Vector-32.svg - 643x311) -->
    <img src="{{ 'illustration-Vector-32.svg' | asset_url }}" class="gift-hero__item" style="top: 55%; left: 62%; width: 46%;" alt="" loading="eager">
    
    <!-- Circle detail (Vector-33.svg) -->
    <img src="{{ 'illustration-Vector-33.svg' | asset_url }}" class="gift-hero__item" style="top: 72%; left: 8%; width: 3%;" alt="" loading="eager">
    
    <!-- Lens circle (Vector-34.svg) -->
    <img src="{{ 'illustration-Vector-34.svg' | asset_url }}" class="gift-hero__item" style="top: 68%; left: 2%; width: 7%;" alt="" loading="eager">
    
    <!-- Film canister (Vector-35.svg) -->
    <img src="{{ 'illustration-Vector-35.svg' | asset_url }}" class="gift-hero__item" style="top: 64%; left: 12%; width: 5%;" alt="" loading="eager">
    
    <!-- Bow tie 2 (Vector-36.svg - 490x313) -->
    <img src="{{ 'illustration-Vector-36.svg' | asset_url }}" class="gift-hero__item" style="top: 42%; left: 40%; width: 22%;" alt="" loading="eager">
    
    <!-- Lens piece (Vector-37.svg) -->
    <img src="{{ 'illustration-Vector-37.svg' | asset_url }}" class="gift-hero__item" style="top: 35%; left: 72%; width: 13%;" alt="" loading="eager">
    
    <!-- Small decorative (Vector-2.svg) -->
    <img src="{{ 'illustration-Vector-2.svg' | asset_url }}" class="gift-hero__item" style="top: 75%; left: 18%; width: 4%;" alt="" loading="eager">

  </div>
  {% endunless %}

  <div class="gift-hero__container">
    <div class="gift-hero__content">
      {% if section.settings.heading != blank %}
        <h1 class="gift-hero__title">{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="gift-hero__description">{{ section.settings.description }}</div>
      {% endif %}

      {% if section.settings.btn_text != blank %}
        <a href="{{ section.settings.btn_link | default: '#' }}" class="gift-hero__btn">
          {{ section.settings.btn_text }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>

  <!-- Bottom tagline -->
  {% if section.settings.bottom_text != blank %}
    <div class="gift-hero__tagline">
      {{ section.settings.bottom_text }}
    </div>
  {% endif %}
</section>

<style>
  .gift-hero {
    position: relative;
    width: 100%;
    min-height: 620px;
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    background-size: cover;
    background-position: center;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  /* Illustration container behaving like background-size: cover to prevent overlap */
  .gift-hero__illustration {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  @media (min-aspect-ratio: 1440/620) {
    .gift-hero__illustration {
      width: 100%;
      height: auto;
      aspect-ratio: 1440/620;
    }
  }

  @media (max-aspect-ratio: 1440/620) {
    .gift-hero__illustration {
      height: 100%;
      width: auto;
      aspect-ratio: 1440/620;
    }
  }

  /* Each illustration item is absolutely positioned */
  .gift-hero__item {
    position: absolute;
    display: block;
    pointer-events: none;
    object-fit: contain;
  }

  .gift-hero__container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 48px 28px;
    width: 100%;
  }

  .gift-hero__content {
    max-width: 420px;
  }

  .gift-hero__title {
    font-size: 48px;
    font-weight: 700;
    color: {{ section.settings.heading_color | default: '#000000' }};
    margin: 0 0 18px 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-family: var(--font-heading--family, Georgia, 'Times New Roman', serif);
  }

  .gift-hero__description {
    font-size: 14px;
    color: {{ section.settings.text_color | default: '#1a1a1a' }};
    line-height: 1.65;
    margin-bottom: 28px;
    max-width: 370px;
  }

  .gift-hero__description p {
    margin: 0;
  }

  .gift-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background-color: {{ section.settings.btn_bg_color | default: '#000000' }};
    color: {{ section.settings.btn_text_color | default: '#ffffff' }};
    padding: 14px 28px;
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    border: none;
  }

  .gift-hero__btn:hover {
    background-color: #d4e600 !important;
    color: #000000 !important;
    transform: translateX(3px);
  }

  .gift-hero__btn svg {
    transition: transform 0.3s ease;
  }

  .gift-hero__btn:hover svg {
    transform: translateX(5px);
  }

  /* Bottom Tagline */
  .gift-hero__tagline {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 16px 40px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: {{ section.settings.tagline_color | default: '#555555' }};
    border-top: 1px solid rgba(0,0,0,0.08);
    background-color: rgba(255,255,255,0.85);
  }

  /* Tablet */
  @media (max-width: 991px) {
    .gift-hero {
      min-height: 500px;
    }

    .gift-hero__container {
      padding: 60px 30px 25px;
    }

    .gift-hero__title {
      font-size: 40px;
    }

    .gift-hero__description {
      font-size: 13px;
    }
  }

  /* Mobile */
  @media (max-width: 749px) {
    .gift-hero {
      min-height: 400px;
    }

    .gift-hero__container {
      padding: 40px 20px 20px;
    }

    .gift-hero__content {
      max-width: 100%;
    }

    .gift-hero__title {
      font-size: 32px;
      margin-bottom: 14px;
    }

    .gift-hero__description {
      font-size: 13px;
      max-width: 100%;
      margin-bottom: 22px;
    }

    .gift-hero__btn {
      padding: 12px 24px;
      font-size: 11px;
      width: 100%;
      justify-content: center;
    }

    .gift-hero__tagline {
      font-size: 8px;
      letter-spacing: 1.5px;
      padding: 14px 16px;
    }

    /* Hide some illustrations on mobile for performance */
    .gift-hero__illustration .gift-hero__item:nth-child(n+15) {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Gift Guide Hero",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image",
      "info": "Leave empty to use the built-in line illustration pattern"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Tagline"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Tagline",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL."
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline Color",
      "default": "#555555"
    }
  ],
  "presets": [
    {
      "name": "Gift Guide Hero"
    }
  ]
}
{% endschema %}
