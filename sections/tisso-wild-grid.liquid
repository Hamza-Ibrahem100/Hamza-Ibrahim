<!-- Tisso In The Wild Grid - Matching Figma Desktop Design -->
<section class="tisso-wild" id="tisso-wild-section">
  <div class="tisso-wild__container">
    <!-- Section Title -->
    {% if section.settings.heading != blank %}
      <h2 class="tisso-wild__title">{{ section.settings.heading }}</h2>
    {% endif %}

    <!-- Image Grid - 3x2 -->
    <div class="tisso-wild__grid">
      {% for block in section.blocks %}
        {%- liquid
          assign product_item = block.settings.product
          assign grid_image = block.settings.image
          if grid_image == blank and product_item != blank
            assign grid_image = product_item.featured_image
          endif
          
          assign p_name = block.settings.product_name
          if p_name == blank and product_item != blank
            assign p_name = product_item.title
          endif

          assign p_price = block.settings.product_price
          if p_price == blank and product_item != blank
            assign p_price = product_item.price | money
          endif

          assign p_link = block.settings.product_link
          if p_link == blank and product_item != blank
            assign p_link = product_item.url
          endif
        -%}
        <div class="tisso-wild__item" {{ block.shopify_attributes }}>
          <div class="tisso-wild__image-wrapper">
            {% if grid_image != blank %}
              <img
                src="{{ grid_image | image_url: width: 800 }}"
                srcset="
                  {{ grid_image | image_url: width: 400 }} 400w,
                  {{ grid_image | image_url: width: 600 }} 600w,
                  {{ grid_image | image_url: width: 800 }} 800w
                "
                sizes="(max-width: 749px) 50vw, 33vw"
                alt="{{ grid_image.alt | default: p_name | default: 'Lifestyle image' }}"
                loading="lazy"
                width="{{ grid_image.width }}"
                height="{{ grid_image.height }}"
                class="tisso-wild__image"
              >
            {% else %}
              <div class="tisso-wild__placeholder">
                {%- assign placeholder_num = forloop.index | modulo: 2 | plus: 1 -%}
                {{ 'lifestyle-' | append: placeholder_num | placeholder_svg_tag: 'tisso-wild__placeholder-svg' }}
              </div>
            {% endif %}

            <!-- Hotspot / Plus Button -->
            {% if p_link != blank %}
              <a href="{{ p_link }}" class="tisso-wild__hotspot hotspot-marker" style="left: {{ block.settings.position_left }}%; top: {{ block.settings.position_top }}%;" data-product-handle="{{ product_item.handle }}" aria-label="{{ p_name | default: 'View product' }}">
                <span class="hotspot-marker__icon">+</span>
              </a>
            {% else %}
              <button class="tisso-wild__hotspot hotspot-marker" style="left: {{ block.settings.position_left }}%; top: {{ block.settings.position_top }}%;" data-product-handle="{{ product_item.handle }}" aria-label="View details" type="button">
                <span class="hotspot-marker__icon">+</span>
              </button>
            {% endif %}

            <!-- Product tooltip on hover -->
            {% if p_name != blank %}
              <div class="tisso-wild__tooltip">
                <span class="tisso-wild__tooltip-name">{{ p_name }}</span>
                {% if p_price != blank %}
                  <span class="tisso-wild__tooltip-price">{{ p_price }}</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
  <!-- Product Popup Modal -->
        <div class="product-popup__top-row">
          <div class="product-popup__image-wrap">
            <img id="popup-product-image" class="product-popup__image" src="" alt="">
          </div>
          <div class="product-popup__info">
            <h3 id="popup-product-title" class="product-popup__title"></h3>
            <p id="popup-product-price" class="product-popup__price"></p>
            <div id="popup-product-description" class="product-popup__description"></div>
          </div>
        </div>

        <div id="popup-options-wrap"></div>

        <button id="popup-add-to-cart" class="product-popup__add-btn" type="button" disabled>
          <span>ADD TO CART</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .tisso-wild {
    width: 100%;
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    padding: 50px 0 0;
  }

  .tisso-wild__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .tisso-wild__title {
    font-size: 26px;
    font-weight: 400;
    color: {{ section.settings.heading_color | default: '#000000' }};
    margin: 0 0 24px 0;
    line-height: 1.3;
    font-family: var(--font-heading--family, Georgia, 'Times New Roman', serif);
    font-style: italic;
  }

  /* Grid Layout - 3 columns matching Figma */
  .tisso-wild__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.grid_gap | default: 6 }}px;
  }

  .tisso-wild__item {
    position: relative;
    overflow: hidden;
  }

  .tisso-wild__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: {{ section.settings.image_ratio | default: '120' }}%;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .tisso-wild__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .tisso-wild__item:hover .tisso-wild__image {
    transform: scale(1.04);
  }

  /* Placeholder */
  .tisso-wild__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tisso-wild__placeholder-svg {
    width: 50%;
    height: auto;
    opacity: 0.25;
  }

  /* Hotspot / Plus Button */
  .tisso-wild__hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: white;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    transition: transform 0.2s ease;
    z-index: 3;
    text-decoration: none;
    padding: 0;
    color: #000;
  }

  .tisso-wild__hotspot:hover {
    transform: translate(-50%, -50%) scale(1.15);
  }

  .hotspot-marker__icon {
    font-size: 18px;
    line-height: 1;
  }

  /* Tooltip */
  .tisso-wild__tooltip {
    position: absolute;
    bottom: 50px;
    left: 14px;
    background-color: #fff;
    color: #000;
    padding: 8px 14px;
    border-radius: 3px;
    box-shadow: 0 3px 16px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: all 0.3s ease;
    z-index: 4;
    white-space: nowrap;
    pointer-events: none;
  }

  .tisso-wild__item:hover .tisso-wild__tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .tisso-wild__tooltip-name {
    display: block;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.3;
  }

  .tisso-wild__tooltip-price {
    display: block;
    font-size: 11px;
    color: #666;
    margin-top: 2px;
  }

  /* Tablet */
  @media (max-width: 991px) {
    .tisso-wild {
      padding: 40px 0 0;
    }

    .tisso-wild__container {
      padding: 0 24px;
    }

    .tisso-wild__title {
      font-size: 22px;
      margin-bottom: 20px;
    }

    .tisso-wild__grid {
      gap: 5px;
    }
  }

  /* Mobile */
  @media (max-width: 749px) {
    .tisso-wild {
      padding: 32px 0 0;
    }

    .tisso-wild__container {
      padding: 0 16px;
    }

    .tisso-wild__title {
      font-size: 18px;
      margin-bottom: 16px;
    }

    .tisso-wild__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4px;
    }

    .tisso-wild__hotspot {
      width: 24px;
      height: 24px;
    }

    .hotspot-marker__icon {
      font-size: 14px;
    }

    .tisso-wild__tooltip {
      display: none;
    }
  }

  /* Very small mobile */
  @media (max-width: 479px) {
    .tisso-wild__image-wrapper {
      padding-bottom: 130%;
    }
  }
  /* Product Popup Styles */
  .product-popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .product-popup-overlay[hidden] {
    display: none;
  }

  .product-popup {
    background: #fff;
    width: 320px;
    max-width: 90vw;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    padding: 20px;
  }

      .product-popup__top-row {
      display: flex;
        gap: 16px;
        margin-bottom: 24px;
      }

      .product-popup__info {
        flex: 1;
        min-width: 0;
      }

  .product-popup__image-wrap {
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .product-popup__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-popup__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .product-popup__price {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
  }

    .product-popup__description {
      font-size: 12px;
      color: #555;
      line-height: 1.5;
      margin-bottom: 0;
    }

  .popup-option-group {
    margin-bottom: 16px;
  }

  .popup-option-label {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 8px;
    display: block;
  }

  .popup-swatch-row {
    display: flex;
    border: 1px solid #ddd;
  }

  .popup-swatch {
    flex: 1;
    padding: 12px;
    text-align: center;
    background: #fff;
    border: none;
    border-right: 1px solid #ddd;
    cursor: pointer;
    font-size: 14px;
  }

  .popup-swatch:last-child {
    border-right: none;
  }

  .popup-swatch.is-selected {
    background: #000;
    color: #fff;
  }

  .popup-size-select {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    font-size: 14px;
    background: #fff;
  }

  .product-popup__add-btn {
    width: 100%;
    padding: 16px;
    background: #000;
    color: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    cursor: pointer;
  }

  .product-popup__add-btn:disabled {
    background: #999;
    cursor: not-allowed;
  }
</style>

<script>
  let currentProduct = null;
  let selectedOptions = {};

  async function openProductPopup(handle) {
    if (!handle) return;

    const res = await fetch(`/products/${handle}.js`);
    currentProduct = await res.json();
    selectedOptions = {};

    document.getElementById('popup-product-image').src = currentProduct.featured_image;
    document.getElementById('popup-product-title').textContent = currentProduct.title;
    document.getElementById('popup-product-description').innerHTML = currentProduct.description;
    updatePriceDisplay(currentProduct.price);

    renderOptions();
    updateSelectedVariant();

    document.getElementById('product-popup-overlay').hidden = false;
  }

  function updatePriceDisplay(cents) {
    const formatted = (cents / 100).toFixed(2).replace('.', ',') + '€';
    document.getElementById('popup-product-price').textContent = formatted;
  }

  function renderOptions() {
    const wrap = document.getElementById('popup-options-wrap');
    wrap.innerHTML = '';

    if (!currentProduct.options || currentProduct.options.length === 0 || (currentProduct.options.length === 1 && currentProduct.options[0] === 'Title')) {
      return; // No options
    }

    currentProduct.options.forEach((optionName, index) => {
      const values = [...new Set(currentProduct.variants.map(v => v[`option${index + 1}`]))];

      const group = document.createElement('div');
      group.className = 'popup-option-group';

      const label = document.createElement('label');
      label.className = 'popup-option-label';
      label.textContent = optionName;
      group.appendChild(label);

      if (optionName.toLowerCase() === 'size') {
        const select = document.createElement('select');
        select.className = 'popup-size-select';
        select.innerHTML = `<option value="">Choose your size</option>` +
          values.map(v => `<option value="${v}">${v}</option>`).join('');
        select.addEventListener('change', (e) => {
          selectedOptions[optionName] = e.target.value;
          updateSelectedVariant();
        });
        group.appendChild(select);
      } else {
        const row = document.createElement('div');
        row.className = 'popup-swatch-row';
        values.forEach(val => {
          const btn = document.createElement('button');
          btn.className = 'popup-swatch';
          btn.type = 'button';
          btn.textContent = val;
          btn.addEventListener('click', () => {
            selectedOptions[optionName] = val;
            row.querySelectorAll('.popup-swatch').forEach(b => b.classList.remove('is-selected'));
            btn.classList.add('is-selected');
            updateSelectedVariant();
          });
          row.appendChild(btn);
        });
        group.appendChild(row);
      }

      wrap.appendChild(group);
    });
  }

  function updateSelectedVariant() {
    const addBtn = document.getElementById('popup-add-to-cart');
    
    // If product has no options (or only default "Title"), just pick the first variant
    if (!currentProduct.options || currentProduct.options.length === 0 || (currentProduct.options.length === 1 && currentProduct.options[0] === 'Title')) {
      const variant = currentProduct.variants[0];
      if (variant) {
        addBtn.disabled = !variant.available;
        addBtn.dataset.variantId = variant.id;
        updatePriceDisplay(variant.price);
      }
      return;
    }

    const allSelected = currentProduct.options.every(opt => selectedOptions[opt]);

    if (!allSelected) {
      addBtn.disabled = true;
      return;
    }

    const variant = currentProduct.variants.find(v =>
      currentProduct.options.every((opt, i) => v[`option${i + 1}`] === selectedOptions[opt])
    );

    if (variant) {
      addBtn.disabled = !variant.available;
      addBtn.dataset.variantId = variant.id;
      updatePriceDisplay(variant.price);
    }
  }

  // ⚙️ اسم/handle منتج "Soft Winter Jacket" - غيّره هنا لو مختلف في متجرك
  const BUNDLE_TRIGGER_PRODUCT = 'soft-winter-jacket';

  /**
   * بيتشيك هل الـ variant المختار حاليًا فيه الخيارين "Black" و"Medium" مع بعض
   * (بغض النظر عن ترتيبهم في الـ options)
   */
  function shouldTriggerBundle(variant) {
    if (!variant) return false;
    const values = [variant.option1, variant.option2, variant.option3]
      .filter(Boolean)
      .map(v => v.toLowerCase());

    return values.includes('black') && values.includes('medium');
  }

  /**
   * بيجيب أول variant متاح لمنتج الـ bundle (Soft Winter Jacket) عن طريق الـ handle
   */
  async function getBundleVariantId() {
    try {
      const res = await fetch(`/products/${BUNDLE_TRIGGER_PRODUCT}.js`);
      if (!res.ok) return null;
      const product = await res.json();
      const availableVariant = product.variants.find(v => v.available);
      return availableVariant ? availableVariant.id : null;
    } catch (err) {
      console.error('Failed to fetch bundle product:', err);
      return null;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Add click listeners to hotspots
    document.querySelectorAll('.hotspot-marker').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const handle = btn.dataset.productHandle;
        if (handle) {
          openProductPopup(handle);
        }
      });
    });

    // Add to cart click
    document.getElementById('popup-add-to-cart').addEventListener('click', async (e) => {
      const variantId = e.currentTarget.dataset.variantId;
      if (!variantId) return;

      e.currentTarget.disabled = true;
      const span = e.currentTarget.querySelector('span');
      const originalText = span.textContent;
      span.textContent = 'ADDING...';

      try {
        // نبني قائمة العناصر اللي هتتضاف - تبدأ بالمنتج المختار
        const itemsToAdd = [{ id: variantId, quantity: 1 }];

        // نلاقي الـ variant الكامل بتاع المنتج الحالي عشان نتأكد من خياراته
        const selectedVariant = currentProduct.variants.find(v => String(v.id) === String(variantId));

        // ✅ الشرط المطلوب: لو الـ variant فيه Black + Medium، نضيف Soft Winter Jacket تلقائي
        if (shouldTriggerBundle(selectedVariant)) {
          const bundleVariantId = await getBundleVariantId();
          if (bundleVariantId) {
            itemsToAdd.push({ id: bundleVariantId, quantity: 1 });
          }
        }

        // نضيف كل العناصر في طلب واحد بستخدام /cart/add.js بصيغة { items: [...] }
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: itemsToAdd })
        });
        
        span.textContent = 'ADDED!';
        setTimeout(() => {
          document.getElementById('product-popup-overlay').hidden = true;
          span.textContent = originalText;
          e.currentTarget.disabled = false;
        }, 1500);
        
      } catch (err) {
        console.error(err);
        e.currentTarget.disabled = false;
        span.textContent = originalText;
      }
    });

    // Close buttons
    document.getElementById('product-popup-close').addEventListener('click', () => {
      document.getElementById('product-popup-overlay').hidden = true;
    });

    document.getElementById('product-popup-overlay').addEventListener('click', (e) => {
      if (e.target.id === 'product-popup-overlay') {
        document.getElementById('product-popup-overlay').hidden = true;
      }
    });
  });
</script>

{% schema %}
{
  "name": "In The Wild Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid Gap",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "100", "label": "Square (1:1)" },
        { "value": "120", "label": "Portrait (5:6)" },
        { "value": "133", "label": "Portrait (3:4)" },
        { "value": "75", "label": "Landscape (4:3)" }
      ],
      "default": "120"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 12,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product (Select a Shopify Product)"
        },
        {
          "type": "range",
          "id": "position_left",
          "label": "Horizontal Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 10
        },
        {
          "type": "range",
          "id": "position_top",
          "label": "Vertical Position (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 90
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (Overrides product image)"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Custom Product Name (Overrides product title)"
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Custom Product Price (Overrides product price)"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Custom Product Link (Overrides product link)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "In The Wild Grid",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
