<!-- Custom Product Grid Section - Modular Structure -->
{{ 'custom-grid.css' | asset_url | stylesheet_tag }}

<section class="custom-product-grid">
  <div class="grid-container">
    {% if section.settings.heading != blank %}
      <h2 class="grid-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="products-wrapper">
      {% for product in section.settings.product_list %}
        <!-- Product Card -->
        <div class="product-card">
          <div class="product-image-wrapper">
            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | img_url: '500x' }}" alt="{{ product.title }}" class="product-img">
            </a>
            <!-- Trigger Button for Pop-up (Connected to JS) -->
            <button class="quick-view-btn hotspot-marker" data-product-handle="{{ product.handle }}" aria-label="Quick View" type="button">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 5V19M5 12H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <div class="product-details">
            <h3 class="product-title">{{ product.title }}</h3>
            <p class="product-price">{{ product.price | money }}</p>
          </div>
        </div>
      {% else %}
        <p>Please select products in the theme editor.</p>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Pop-up Modal handled globally by quick-add-modal in layout/theme.liquid -->

<!-- Section Script -->
<script src="{{ 'custom-grid.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Select Products",
      "limit": 8
    }
  ],
  "presets": [
    {
      "name": "Custom Grid"
    }
  ]
}
{% endschema %}