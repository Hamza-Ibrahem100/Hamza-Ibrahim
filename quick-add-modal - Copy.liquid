{% comment %}
  Global Quick Add Modal
  Include ONCE per page — best placed in layout/theme.liquid right before </body>.
  Opened via JS: openProductPopup('product-handle')
{% endcomment %}

{{ 'quick-add.css' | asset_url | stylesheet_tag }}

<div class="qa-backdrop" id="qaBackdrop">
  <div class="qa-modal" id="qaModal" role="dialog" aria-modal="true" aria-labelledby="qaTitle">

    <button class="qa-close" id="qaClose" aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none"><path d="M4 4L20 20M20 4L4 20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
    </button>

    <div class="qa-loading" id="qaLoading">Loading…</div>

    <div class="qa-content" id="qaContent" hidden>
      <div class="qa-top">
        <div class="qa-img"><img id="qaImg" src="" alt=""></div>
        <div>
          <div class="qa-title" id="qaTitle"></div>
          <div class="qa-price" id="qaPrice"></div>
        </div>
      </div>

      <div class="qa-body">
        <div class="qa-desc" id="qaDesc"></div>

        <div id="qaOptions"></div>

        <p class="qa-error" id="qaError" hidden></p>

        <button class="qa-add-btn" id="qaAddBtn" type="button">
          <span id="qaAddBtnLabel">Add to Cart</span>
          <svg viewBox="0 0 24 24" fill="none"><path d="M4 12H20M20 12L13 5M20 12L13 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

  </div>
</div>

<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
